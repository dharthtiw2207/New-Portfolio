el} href={href} onClick={(e) => scrollTo(e, href)}>\n              {label}\n            </a>\n          ))}\n        </div>\n      )}\n    </nav>\n  );\n};\n\nexport default Navbar;\n"],"mappings":"AAAA,OAASA,QAAQ,CAAEC,SAAS,KAAQ,OAAO,CAC3C,MAAO,cAAc,CAAC,OAAAC,GAAA,IAAAC,IAAA,CAAAC,IAAA,IAAAC,KAAA,yBAEtB,KAAM,CAAAC,SAAS,CAAG,CAChB,CAAEC,KAAK,CAAE,MAAM,CAAQC,IAAI,CAAE,OAAc,CAAC,CAC5C,CAAED,KAAK,CAAE,OAAO,CAAOC,IAAI,CAAE,QAAc,CAAC,CAC5C,CAAED,KAAK,CAAE,YAAY,CAAEC,IAAI,CAAE,aAAc,CAAC,CAC5C,CAAED,KAAK,CAAE,UAAU,CAAIC,IAAI,CAAE,WAAc,CAAC,CAC5C,CAAED,KAAK,CAAE,QAAQ,CAAMC,IAAI,CAAE,SAAc,CAAC,CAC5C,CAAED,KAAK,CAAE,SAAS,CAAKC,IAAI,CAAE,UAAc,CAAC,CAC7C,CAED,KAAM,CAAAC,MAAM,CAAGA,CAAA,GAAM,CACnB,KAAM,CAACC,QAAQ,CAAMC,WAAW,CAAC,CAAOX,QAAQ,CAAC,KAAK,CAAC,CACvD,KAAM,CAACY,QAAQ,CAAMC,WAAW,CAAC,CAAOb,QAAQ,CAAC,KAAK,CAAC,CAEvDC,SAAS,CAAC,IAAM,CACd,KAAM,CAAAa,QAAQ,CAAGA,CAAA,GAAMH,WAAW,CAACI,MAAM,CAACC,OAAO,CAAG,EAAE,CAAC,CACvDD,MAAM,CAACE,gBAAgB,CAAC,QAAQ,CAAEH,QAAQ,CAAC,CAC3C,MAAO,IAAMC,MAAM,CAACG,mBAAmB,CAAC,QAAQ,CAAEJ,QAAQ,CAAC,CAC7D,CAAC,CAAE,EAAE,CAAC,CAEN,KAAM,CAAAK,QAAQ,CAAGA,CAACC,CAAC,CAAEZ,IAAI,GAAK,KAAAa,qBAAA,CAC5BD,CAAC,CAACE,cAAc,CAAC,CAAC,CAClBT,WAAW,CAAC,KAAK,CAAC,CAClB,CAAAQ,qBAAA,CAAAE,QAAQ,CAACC,aAAa,CAAChB,IAAI,CAAC,UAAAa,qBAAA,iBAA5BA,qBAAA,CAA8BI,cAAc,CAAC,CAAEC,QAAQ,CAAE,QAAS,CAAC,CAAC,CACtE,CAAC,CAED,mBACErB,KAAA,QAAKsB,SAAS,CAAE,UAAUjB,QAAQ,CAAG,UAAU,CAAG,EAAE,EAAG,CAAAkB,QAAA,eACrDzB,IAAA,QAAKwB,SAAS,CAAC,UAAU,CAAAC,QAAA,CAAC,KAAG,CAAK,CAAC,cAGnCzB,IAAA,OAAIwB,SAAS,CAAC,WAAW,CAAAC,QAAA,CACtBtB,SAAS,CAACuB,GAAG,CAACC,IAAA,MAAC,CAAEvB,KAAK,CAAEC,IAAK,CAAC,CAAAsB,IAAA,oBAC7B3B,IAAA,OAAAyB,QAAA,cACEzB,IAAA,MAAGK,IAAI,CAAEA,IAAK,CAACuB,OAAO,CAAGX,CAAC,EAAKD,QAAQ,CAACC,CAAC,CAAEZ,IAAI,CAAE,CAAAoB,QAAA,CAAErB,KAAK,CAAI,CAAC,EADtDA,KAEL,CAAC,EACN,CAAC,CACA,CAAC,cAGLF,KAAA,WACEsB,SAAS,CAAE,aAAaf,QAAQ,CAAG,MAAM,CAAG,EAAE,EAAG,CACjDmB,OAAO,CAAEA,CAAA,GAAMlB,WAAW,CAAC,CAACD,QAAQ,CAAE,CACtC,aAAW,aAAa,CAAAgB,QAAA,eAExBzB,IAAA,UAAO,CAAC,cAAAA,IAAA,UAAO,CAAC,cAAAA,IAAA,UA